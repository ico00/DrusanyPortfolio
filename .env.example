# Base URL stranice (za Open Graph, metadata, canonical linkovi)
# Koristi se u layout.tsx za metadataBase
# Canonical URL = NEXT_PUBLIC_SITE_URL + path (npr. https://drusany.com/blog/251228-advent-2025)
NEXT_PUBLIC_SITE_URL=https://drusany.com

# Rate limiting za admin API (opcionalno; default: 60 req/min po IP)
# RATE_LIMIT_MAX_REQUESTS=60
# RATE_LIMIT_WINDOW_MS=60000

# rsync over SSH (preporučeno) – samo promijenjene datoteke, brzo
# SSH_HOST=drusany.com
# SSH_USER=drusanyc
# SSH_PATH=/home/drusanyc/public_html
# SSH_PORT=21098

# FTP deploy – alternativa ako nemaš SSH
# FTP_HOST=drusany.com
# FTP_USER=drusanyc
# FTP_PASS=tvoja_lozinka
# FTP_REMOTE_PATH=/public_html
